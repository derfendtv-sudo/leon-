        elif "выход" in query or "отключись" in query:
            self.speak("Перехожу в спящий режим. Удачи, Сэр.")
            sys.exit()
        
        # === 8. ОБРАЩЕНИЕ К НЕЙРОСЕТИ ===
        else:
