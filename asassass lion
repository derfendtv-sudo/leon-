                self.speak("Память забита, Сэр. Рекомендую закрыть лишние программы.")
            return

        elif "переведи текст" in query:
            text = pyperclip.paste()
            if text:
                self.speak("Перевожу скопированный текст.")
                ans = self.ask_ai(f"Переведи этот текст на русский: {text}")
