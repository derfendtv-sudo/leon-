        elif "продолжи" in query or "играй видео" in query:
            self.speak("Продолжаю воспроизведение.")
            pyautogui.press('space')
            return

        # === 5. СУПЕР-УМНОЕ ОТКРЫТИЕ ПРИЛОЖЕНИЙ (ТОЧЕЧНОЕ ИСПРАВЛЕНИЕ) ===
        elif query.startswith("открой "):
            app_name = query.replace("открой ", "").strip()
            
            websites = {
                "ютуб": "https://youtube.com", "youtube": "https://youtube.com",
                "вк": "https://vk.com", "vk": "https://vk.com"
            }
            for web_key, url in websites.items():
                if web_key in app_name: 
                    self.speak(f"Открываю {web_key} в браузере, Сэр.")
                    webbrowser.open(url)
                    return

            smart_dict = {
                "гугл": "google chrome", "хром": "google chrome", "chrome": "google chrome",
                "опер": "opera gx", "opera": "opera gx", 
                "дискорд": "discord", "discord": "discord",
                "стим": "steam", "steam": "steam",
                "телег": "telegram desktop", "telegram": "telegram desktop", 
                "майн": "minecraft", "minecraft": "minecraft",
                "обс": "obs studio", "obs": "obs studio",
                "капкут": "capcut", "capcut": "capcut",
                "эпик": "epic games", "epic": "epic games",
                "аид": "aida64 extreme", "aida": "aida64 extreme",
                "темп": "core temp", "temp": "core temp"
            }

            target_app = app_name 
            for key, real_name in smart_dict.items():
                if key in app_name:
                    target_app = real_name
                    break 

            self.speak(f"Выполняю запуск: {target_app}.")
            
            # Приоритетный прямой запуск файлов (чтобы не дергать строку поиска Windows)
            direct_paths = {
                "discord": os.path.expandvars(r"%LOCALAPPDATA%\Discord\Update.exe"),
                "telegram desktop": os.path.expandvars(r"%APPDATA%\Telegram Desktop\Telegram.exe"),
                "steam": r"C:\Program Files (x86)\Steam\steam.exe",
                "opera gx": os.path.expandvars(r"%LOCALAPPDATA%\Programs\Opera GX\launcher.exe"),
                "google chrome": r"C:\Program Files\Google\Chrome\Application\chrome.exe"
            }

            try: 
                launched = False
                if target_app in direct_paths:
                    app_path = direct_paths[target_app]
                    if os.path.exists(app_path):
                        if target_app == "discord":
                            subprocess.Popen([app_path, "--processStart", "Discord.exe"])
                        else:
                            os.startfile(app_path)
                        launched = True
                
                if not launched:
                    # Резервный запуск через AppOpener, если прямого пути нет
